load! /code/util

pub fn cmd_gc: (args :vec[str]) {
    set lib_dir = use! util::owl_home_modules()
    set has_libs = fs_exists(lib_dir)
    set removed = 0 :i64 mut
    set kept = 0 :i64 mut

    if has_libs {
        set pkg_list = use! util::trim(proc::run("ls \"" + lib_dir + "\" 2>/dev/null || true"))
        if pkg_list != "" {
            set entries = use! util::split(pkg_list "\n")
            set ni = len(entries)
            set i_pkg = 0 :i64 mut
            while i_pkg < ni {
                set pkg = use! util::trim(use! util::list_get(entries i_pkg))
                if pkg != "" {
                    if fs_exists(lib_dir + "/" + pkg) {
                        set pkg_dir = lib_dir + "/" + pkg

                        set ver_list = use! util::trim(proc::run("ls \"" + pkg_dir + "\" 2>/dev/null || true"))
                        set vertries = use! util::split(ver_list "\n")
                        set nv = len(vertries)
                        set i_ver = 0 :i64 mut
                        while i_ver < nv {
                            set ver = use! util::trim(use! util::list_get(vertries i_ver))
                            set ver_dir = pkg_dir + "/" + ver
                            if !fs_exists(ver_dir + "/meta.toml") {
                                use proc::run("rm -rf \"" + ver_dir + "\" 2>/dev/null || true")
                                set removed += 1
                            } else {
                                set kept += 1
                            }
                            set i_ver += 1
                        }

                        set rem_vers = use! util::trim(proc::run("ls \"" + pkg_dir + "\" 2>/dev/null || true"))
                        if rem_vers == "" {
                            use proc::run("rmdir \"" + pkg_dir + "\" 2>/dev/null || true")
                        }
                    }
                }
                set i_pkg += 1
            }
        }
    }

    use dasu("  gc: " + use! util::i64_to_string(removed) + " orphaned versions removed, " + use! util::i64_to_string(kept) + " kept")
    use dasu("  done")
}
