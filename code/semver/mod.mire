load! /code/util

pub fn parse_version: (ver :&str) :str {
    set trimmed = use! util::trim(ver)
    set result = "" :str mut
    if trimmed == "" { set result = "0.0.0" }
    if trimmed != "" {
        set dot1 = strings::index(trimmed ".")
        if dot1 < 0 { set result = trimmed + ".0.0" }
        if dot1 >= 0 {
            set major = strings::substr(trimmed 0 dot1)
            set rest = strings::substr(trimmed dot1 + 1 9999)
            set dot2 = strings::index(rest ".")
            if dot2 < 0 { set result = major + "." + rest + ".0" }
            if dot2 >= 0 {
                set minor = strings::substr(rest 0 dot2)
                set patch = strings::substr(rest dot2 + 1 9999)
                set result = major + "." + minor + "." + patch
            }
        }
    }
    return result
}

pub fn compare_versions: (a :&str b :&str) :i64 {
    set pa = use! parse_version(a)
    set pb = use! parse_version(b)

    set dot1a = strings::index(pa ".")
    set major_a = use! util::string_to_i64(strings::substr(pa 0 dot1a))
    set rest_a = strings::substr(pa dot1a + 1 9999)
    set dot2a = strings::index(rest_a ".")
    set minor_a = use! util::string_to_i64(strings::substr(rest_a 0 dot2a))
    set patch_a = use! util::string_to_i64(strings::substr(rest_a dot2a + 1 9999))

    set dot1b = strings::index(pb ".")
    set major_b = use! util::string_to_i64(strings::substr(pb 0 dot1b))
    set rest_b = strings::substr(pb dot1b + 1 9999)
    set dot2b = strings::index(rest_b ".")
    set minor_b = use! util::string_to_i64(strings::substr(rest_b 0 dot2b))
    set patch_b = use! util::string_to_i64(strings::substr(rest_b dot2b + 1 9999))

    set result = 0 :i64 mut
    if major_a < major_b { set result = -1 }
    if major_a > major_b { set result = 1 }
    if major_a == major_b {
        if minor_a < minor_b { set result = -1 }
        if minor_a > minor_b { set result = 1 }
        if minor_a == minor_b {
            if patch_a < patch_b { set result = -1 }
            if patch_a > patch_b { set result = 1 }
        }
    }
    return result
}

pub fn get_constraint_type: (c :&str) :str {
    set result = "=" :str mut
    if use! util::startswith(c "^") { set result = "^" }
    if use! util::startswith(c "~") { set result = "~" }
    if use! util::startswith(c ">=") { set result = ">=" }
    if use! util::startswith(c "<=") { set result = "<=" }
    if use! util::startswith(c ">") { set result = ">" }
    if use! util::startswith(c "<") { set result = "<" }
    return result
}

pub fn get_constraint_version: (c :&str) :str {
    set trimmed = use! util::trim(c)
    set result = trimmed :str mut
    if use! util::startswith(trimmed "^") { set result = use! util::trim(strings::substr(trimmed 1 len(trimmed) - 1)) }
    if use! util::startswith(trimmed "~") { set result = use! util::trim(strings::substr(trimmed 1 len(trimmed) - 1)) }
    if use! util::startswith(trimmed ">=") { set result = use! util::trim(strings::substr(trimmed 2 len(trimmed) - 2)) }
    if use! util::startswith(trimmed "<=") { set result = use! util::trim(strings::substr(trimmed 2 len(trimmed) - 2)) }
    if use! util::startswith(trimmed ">") { set result = use! util::trim(strings::substr(trimmed 1 len(trimmed) - 1)) }
    if use! util::startswith(trimmed "<") { set result = use! util::trim(strings::substr(trimmed 1 len(trimmed) - 1)) }
    return result
}

pub fn constraint_matches: (version :&str constraint :&str) :bool {
    set c = use! util::trim(constraint)
    set v = use! util::trim(version)

    set result = false :bool mut
    if c == "*" || c == "latest" { set result = true }
    if c != "*" && c != "latest" {
        set op = use! get_constraint_type(c)
        set ver_str = use! get_constraint_version(c)
        set pv = use! parse_version(ver_str)
        set vv = use! parse_version(v)

        if op == ">=" { set result = use! compare_versions(vv pv) >= 0 }
        if op == "<=" { set result = use! compare_versions(vv pv) <= 0 }
        if op == ">" { set result = use! compare_versions(vv pv) > 0 }
        if op == "<" { set result = use! compare_versions(vv pv) < 0 }

        if op == "^" {
            set result = use! compare_versions(vv pv) >= 0
            if use! compare_versions(vv pv) >= 0 {
                set dot1 = strings::index(pv ".")
                set major_s = strings::substr(pv 0 dot1)
                set major = use! util::string_to_i64(major_s)
                set upper = use! util::i64_to_string(major + 1) + ".0.0"
                set result = use! compare_versions(vv upper) < 0
            }
        }

        if op == "~" {
            set result = use! compare_versions(vv pv) >= 0
            if use! compare_versions(vv pv) >= 0 {
                set dot1 = strings::index(pv ".")
                set rest = strings::substr(pv dot1 + 1 9999)
                set dot2 = strings::index(rest ".")
                set major_s = strings::substr(pv 0 dot1)
                set minor_s = strings::substr(rest 0 dot2)
                set minor = use! util::string_to_i64(minor_s)
                set upper = major_s + "." + use! util::i64_to_string(minor + 1) + ".0"
                set result = use! compare_versions(vv upper) < 0
            }
        }

        if op == "=" { set result = use! compare_versions(vv pv) == 0 }
    }
    return result
}

pub fn count_lines: (s :&str) :i64 {
    set n = 0 :i64 mut
    set pos = 0 :i64 mut
    set slen = len(s)
    while pos < slen {
        set ch = strings::substr(s pos 1)
        if ch == "\n" { set n += 1 }
        set pos += 1
    }
    return n + 1
}

pub fn first_token: (s :&str) :str {
    set trimmed = use! util::trim(s)
    set result = trimmed :str mut
    set sp = strings::index(trimmed " ")
    if sp >= 0 { set result = strings::substr(trimmed 0 sp) }
    return result
}

pub fn rest_tokens: (s :&str) :str {
    set trimmed = use! util::trim(s)
    set result = "" :str mut
    set sp = strings::index(trimmed " ")
    if sp >= 0 { set result = use! util::trim(strings::substr(trimmed sp + 1 9999)) }
    return result
}

pub fn best_match: (versions :&str constraint :&str) :str {
    set result = "" :str mut
    if versions != "" {
        set best = "" :str mut
        set vlist = use! util::trim(versions) :str mut
        while vlist != "" {
            set ver = use! first_token(vlist)
            set vlist = use! rest_tokens(vlist)
            if ver != "" {
                if use! constraint_matches(ver constraint) {
                    if best == "" { set best = ver } else {
                        if use! compare_versions(ver best) > 0 { set best = ver }
                    }
                }
            }
        }
        set result = best
    }
    return result
}

pub fn extract_str_val: (line :&str) :str {
    set trimmed = use! util::trim(line)
    set result = "" :str mut
    set eq_pos = strings::index(trimmed "=")
    if eq_pos >= 0 {
        set val = use! util::trim(strings::substr(trimmed eq_pos + 1 9999)) :str mut
        if use! util::startswith(val "\"") { set val = strings::substr(val 1 len(val) - 1) }
        if use! util::endswith(val "\"") { set val = strings::substr(val 0 len(val) - 1) }
        set result = use! util::trim(val)
    }
    return result
}

pub fn nth_line: (s :&str n :i64) :str {
    set pos = 0 :i64 mut
    set cur = 0 :i64 mut
    set slen = len(s)
    while pos < slen && cur < n {
        set ch = strings::substr(s pos 1)
        if ch == "\n" { set cur += 1 }
        set pos += 1
    }
    set result = "" :str mut
    if pos < slen {
        set nl = strings::index(strings::substr(s pos slen - pos) "\n")
        if nl < 0 { set result = strings::substr(s pos slen - pos) }
        if nl >= 0 { set result = strings::substr(s pos nl) }
    }
    return result
}

pub fn resolve_from_registry: (name :&str constraint :&str) :str {
    set result = "" :str mut
    set cached = use! get_cached_resolution(name constraint)
    if cached != "" { set result = cached }
    if cached == "" {
        set reg_dir = use! util::owl_home_registries()
        set reg_list = use! util::trim(proc::run("ls \"" + reg_dir + "\" 2>/dev/null || true"))
        if reg_list == "" { set result = "" }
        if reg_list != "" {
            set all_versions = "" :str mut
            set entries = use! util::split(reg_list "\n")
            set ni = len(entries)
            set i_reg = 0 :i64 mut
            while i_reg < ni {
                set reg_name = use! util::trim(use! util::list_get(entries i_reg))
                if reg_name != "" {
                    set index_path = reg_dir + "/" + reg_name + "/index.toml"
                    set version_cmd = "grep -A1 '^name = \"" + *name + "\"' \"" + index_path + "\" | grep '^version =' | sed 's/.*= \"\\(.*\\)\"/\\1/' | head -1"
                    set versions = use! util::trim(proc::run(version_cmd))
                    if versions != "" {
                        if all_versions == "" { set all_versions = versions } else { set all_versions = all_versions + " " + versions }
                    }
                }
                set i_reg += 1
            }
            if all_versions == "" { set result = "" }
            if all_versions != "" {
                set best = use! best_match(all_versions constraint)
                if best != "" {
                    use! cache_resolution(name constraint best)
                }
                set result = best
            }
        }
    }
    return result
}

pub fn check_version: (name :&str constraint :&str) {
    set n = use! util::trim(name)
    set c = use! util::trim(constraint)
    set resolved = use! resolve_from_registry(name constraint)
    if resolved == "" {
        use dasu("  warning: \"" + n + "\" not found in any registry for constraint \"" + c + "\"")
    } else {
        use dasu("  resolved " + n + " " + c + " -> " + resolved)
    }
}

pub fn cache_resolution: (name :&str constraint :&str version :&str) {
    set cache_file = use! util::owl_home_cache_resolution()
    set n = use! util::trim(name)
    set c = use! util::trim(constraint)
    set v = use! util::trim(version)
    if n == "" || c == "" { return }
    set entry = n + "|" + c + "=\"" + v + "\"\n"
    use fs_write(cache_file entry)
}

pub fn get_cached_resolution: (name :&str constraint :&str) :str {
    set cache_file = use! util::owl_home_cache_resolution()
    set result = "" :str mut
    if fs_exists(cache_file) {
        set content = fs::read(cache_file)
        set n = use! util::trim(name)
        set c = use! util::trim(constraint)
        set prefix = n + "|" + c + "="
        set pos = strings::index(content prefix)
        if pos >= 0 {
            set after = strings::substr(content pos + len(prefix) 9999)
            if use! util::startswith(after "\"") {
                set rest = strings::substr(after 1 9999)
                set endq = strings::index(rest "\"")
                if endq >= 0 { set result = strings::substr(rest 0 endq) }
            }
        }
    }
    return result
}
