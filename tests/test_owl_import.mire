// owl tool test: owl import adds dependencies to owl.toml
load kioto
load testlib

pub fn main: () {
    use dasu("--- test: owl import ---")

    set ts = strings.trim(proc::run("date +%s%N"))
    set test_base = "/tmp/owl_import_test_" + ts
    set proj_dir = test_base + "/testimport"

    proc::run("mkdir -p " + test_base)
    proc::run("cd " + test_base + " && ~/.local/bin/owl new testimport 2>&1")

    set import_cmd = "cd " + proj_dir + " && ~/.local/bin/owl import mylib --path \"./libs/mylib\" 2>&1"
    set import_out = proc::run(import_cmd)

    set has_imported = strings.contains(import_out "imported")
    if has_imported {
        use dasu("  owl import --path: ok")
    } else {
        use dasu("  owl import output:")
        use dasu(import_out)
    }

    set dep_check = "grep \"mylib\" " + proj_dir + "/owl.toml && echo 'yes' || echo 'no'"
    set has_dep = strings.trim(proc::run(dep_check))
    if has_dep == "yes" {
        use dasu("  dependency added to owl.toml: ok")
    } else {
        use dasu("  dependency NOT found in owl.toml")
    }

    set dup_cmd = "cd " + proj_dir + " && ~/.local/bin/owl import mylib --path \"./libs/other\" 2>&1"
    set dup_out = proc::run(dup_cmd)
    set has_dup_error = strings.contains(dup_out "already")
    if has_dup_error {
        use dasu("  duplicate import rejected: ok")
    } else {
        use dasu("  duplicate import output:")
        use dasu(dup_out)
    }

    proc::run("rm -rf " + test_base)
    use dasu("test_owl_import complete")
}
